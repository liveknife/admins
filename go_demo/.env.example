# ══════════════════════════════════════════════
# Admin Platform - 环境变量完整参考
#
# 使用方式：
#   1. 复制对应环境模板:  cp .env.development .env   或   cp .env.production .env
#   2. 填入实际值（特别是密码和密钥）
#   3. 启动: go run .
#
# 系统自动按 APP_ENV 加载:
#   APP_ENV=development → .env.development > .env
#   APP_ENV=production  → .env.production  > .env
#
# Go 原生不读 .env 文件，本项目使用 godotenv 自动加载
# ══════════════════════════════════════════════

# ── 环境 ──
APP_ENV=development              # development | production (默认 development)
PORT=8080                        # HTTP 监听端口
GIN_MODE=debug                   # debug | release (生产必须 release)

# ═════════════════════════════════════════
#  数据库配置
# ═════════════════════════════════════════
DATABASE_TYPE=postgres           # postgres | mysql

# ── 方式一：完整 DSN（优先级最高）──
# DATABASE_DSN="postgres://user:pass@host:5432/db?sslmode=disable"

# ── 方式二：PostgreSQL 独立参数（DSN 未设置时生效）──
PG_HOST=localhost                # 主机地址
PG_PORT=5432                     # 端口
PG_USER=postgres                 # 用户名
PG_PASSWORD=your_password        # 密码（必填）
PG_DB_NAME=admins                # 数据库名
PG_SSL_MODE=disable              # disable | require | verify-full

# ── 方式二：MySQL 独立参数（DSN 未设置时生效）──
# MYSQL_HOST=localhost            # 主机地址
# MYSQL_PORT=3306                 # 端口
# MYSQL_USER=root                 # 用户名
# MYSQL_PASSWORD=your_password    # 密码（必填）
# MYSQL_DB_NAME=admins            # 数据库名

# 连接池
DB_MAX_OPEN_CONN=25              # 最大打开连接数
DB_MAX_IDLE_CONN=5               # 最大空闲连接数

# ═════════════════════════════════════════
#  Redis 配置（可选，未设置则跳过）
# ═════════════════════════════════════════
# REDIS_URL=redis://:password@host:6379/0   # 完整 URL（优先级最高）
REDIS_HOST=localhost             # 主机
REDIS_PORT=6379                  # 端口
REDIS_PASSWORD=                  # 密码
REDIS_DB=0                       # DB 编号 0~15
REDIS_POOL_SIZE=10               # 连接池大小

# ═════════════════════════════════════════
#  默认管理员账号（首次启动自动创建）
# ═════════════════════════════════════════
DEFAULT_ADMIN_USERNAME=admin     # 用户名
DEFAULT_ADMIN_EMAIL=admin@example.com  # 邮箱（唯一标识）
DEFAULT_ADMIN_PHONE=13800000000       # 手机号
DEFAULT_ADMIN_PASSWORD=Admin@123     # 密码（需满足复杂度：8位+大小写+数字+特殊字符）

# ═════════════════════════════════════════
#  JWT / 安全
# ═════════════════════════════════════════
JWT_SECRET=please-change-this-secret-in-production  # 生产环境必须 >= 32 字符随机串，禁止使用默认值

# ── CORS 跨域配置 ──
CORS_ALLOWED_ORIGINS=             # 允许的 Origin 列表，逗号分隔。生产必填，开发环境留空则默认允许 localhost:*；示例：https://admin.example.com,https://app.example.com

# ═════════════════════════════════════════
#  邮件服务（SMTP）— 用于密码重置等通知场景
# ═════════════════════════════════════════
# 未设置 SMTP_HOST 时邮件功能进入 dry-run 模式（仅日志打印不实际发送）
SMTP_HOST=                        # SMTP 服务器地址（如 smtp.gmail.com, smtp.qq.com）
SMTP_PORT=587                     # SMTP 端口（587/TLS 或 465/SSL）
SMTP_USER=                        # 发件邮箱账号
SMTP_PASSWORD=                    # 发件邮箱密码或应用专用密码
SMTP_FROM=                        # 发件人名称/邮箱（留空则使用 SMTP_USER）

# ═════════════════════════════════════════
#  RAG / 大模型（可选）
# ═════════════════════════════════════════
# 不配置时仍会使用本地轻量 embedding 做知识库检索，但不会调用大模型生成。
# OpenAI 兼容接口示例：OpenAI、DeepSeek、Ollama /v1 等。
AI_PROVIDER=                      # openai | deepseek | ollama；设置 AI_BASE_URL 时可留空
AI_BASE_URL=                      # 例如 https://api.openai.com/v1、https://api.deepseek.com/v1、http://localhost:11434/v1
AI_API_KEY=                       # Ollama 本地通常可留空
AI_CHAT_MODEL=                    # 例如 gpt-4.1-mini、deepseek-chat、qwen2.5:7b
AI_EMBEDDING_MODEL=               # 例如 text-embedding-3-small、nomic-embed-text
RAG_TOP_K=6                       # 每次问答注入的知识块数量
